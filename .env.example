# Copy this file to `.env` and fill in the values.
# `.env` is in .gitignore — NEVER commit it.

# --- PostgreSQL / pgvector ---
POSTGRES_DB=contract_assistant
POSTGRES_USER=contract_user
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=change_me_dev_only_secret_key
DJANGO_DEBUG=True
# Comma-separated hosts from which we accept requests
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Ollama (local LLM + embeddings) ---
# The app runs entirely locally via Ollama — no cloud API keys.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# LLM model for the answers (Stage 4)
OLLAMA_CHAT_MODEL=llama3.1:8b
